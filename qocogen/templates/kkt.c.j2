{% if generate_ruiz %}
void ruiz_equilibration(Workspace* work) {
   for (int i = 0; i < work->n; ++i) {
       work->Druiz[i] = 1.0;
       work->Dinvruiz[i] = 1.0;
   }
   for (int i = 0; i < work->p; ++i) {
       work->Eruiz[i] = 1.0;
       work->Einvruiz[i] = 1.0;
   }
   for (int i = 0; i < work->m; ++i) {
       work->Fruiz[i] = 1.0;
       work->Finvruiz[i] = 1.0;
   }
   work->k = 1.0;
   work->kinv = 1.0;

   for (int iter = 0; iter < work->settings.ruiz_iters; ++iter) {
       for (int i = 0; i < work->n + work->m + work->p; ++i) {
           work->xyzbuff[i] = 0.0;
       }

       KKTrow_inf_norm(work->xyzbuff, work);
       for (int i = 0; i < work->n + work->m + work->p; ++i) {
           work->xyzbuff[i] = safe_div(1.0, qoco_sqrt(work->xyzbuff[i]));
       }

       // g = 1 / max(mean(Pinf), norm(c, "inf"));
       double g = 0.0;
       Pinf_norm(work->xbuff, work);
       for (int i = 0; i < work->n; ++i) {
           g += work->xbuff[i];
       }
       g /= work->n;
       double cinf = qoco_custom_inf_norm(work->c, work->n);
       g = qoco_max(g, cinf);
       g = safe_div(1.0, g);
       work->k *= g;

       // Make scalings for all variables in a second-order cone equal.
       int idx = work->l;
       for (int j = 0; j < work->nsoc; ++j) {
           for (int k = idx + 1; k < idx + work->q[j]; ++k) {
               work->xyzbuff[work->n + work->p + k] = work->xyzbuff[work->n + work->p + idx];
           }
       idx += work->q[j];
       }

       // Scale P by g.
       qoco_custom_scale_arrayf(work->P, work->P, g, work->Pnnz);
       // Scale c.
       qoco_custom_scale_arrayf(work->c, work->c, g, work->n);
       qoco_custom_ew_product(work->c, work->xyzbuff, work->c, work->n);

       // Scale P, A, G.
       ruiz_scale_KKT(work->xyzbuff, work);

       // Update scaling matrices.
       qoco_custom_ew_product(work->Druiz, work->xyzbuff, work->Druiz, work->n);
       qoco_custom_ew_product(work->Eruiz, &work->xyzbuff[work->n], work->Eruiz, work->p);
       qoco_custom_ew_product(work->Fruiz, &work->xyzbuff[work->n + work->p], work->Fruiz, work->m);
   }
   // Scale b.
   qoco_custom_ew_product(work->b, work->Eruiz, work->b, work->p);

   // Scale h.
   qoco_custom_ew_product(work->h, work->Fruiz, work->h, work->m);

   // Compute Dinv, Einv, Finv.
   work->kinv = safe_div(1.0, work->k);
   for (int i = 0; i < work->n; ++i) {
       work->Dinvruiz[i] = safe_div(1.0, work->Druiz[i]);
   }
   for (int i = 0; i < work->p; ++i) {
       work->Einvruiz[i] = safe_div(1.0, work->Eruiz[i]);
   }
   for (int i = 0; i < work->m; ++i) {
       work->Finvruiz[i] = safe_div(1.0, work->Fruiz[i]);
   }
}

void unequilibrate_data(Workspace* work) {
   qoco_custom_copy_arrayf(work->Dinvruiz, work->xyzbuff, work->n);
   qoco_custom_copy_arrayf(work->Einvruiz, &work->xyzbuff[work->n], work->p);
   qoco_custom_copy_arrayf(work->Finvruiz, &work->xyzbuff[work->n + work->p], work->m);
   ruiz_scale_KKT(work->xyzbuff, work);
   qoco_custom_scale_arrayf(work->P, work->P, work->kinv, work->Pnnz);
   qoco_custom_scale_arrayf(work->c, work->c, work->kinv, work->n);
   qoco_custom_ew_product(work->c, work->Dinvruiz, work->c, work->n);
   qoco_custom_ew_product(work->b, work->Einvruiz, work->b, work->p);
   qoco_custom_ew_product(work->h, work->Finvruiz, work->h, work->m);
}

