void compute_kkt_residual(Workspace* work) {
   // Zero out NT Block.
   for (int i = 0; i < work->Wnnz; ++i) {
       work->WtW[i] = 0.0;
   }
   // Load [x;y;z] into xyzbuff.
   for (int i = 0; i < work->n; ++i) {
       work->xyzbuff[i] = work->x[i];
   }
   for (int i = 0; i < work->p; ++i) {
       work->xyzbuff[i + work->n] = work->y[i];
   }
   for (int i = 0; i < work->m; ++i) {
       work->xyzbuff[i + work->n + work->p] = work->z[i];
   }

   // Permute xyzbuff and store into xyz.
   for (int i = 0; i < work->n + work->p + work->m; ++i) {
       work->xyz[i] = work->xyzbuff[work->perm[i]];
   }

   KKT_perm_product(work->xyz, work->xyzbuff, work);

   // Permute xyzbuff and store into xyz.
   for (int i = 0; i < work->n + work->p + work->m; ++i) {
       work->kkt_res[work->perm[i]] = work->xyzbuff[i];
   }

   // Add [c;-b;-h+s].
   for (int i = 0; i < work->n; ++i) {
       work->kkt_res[i] += work->c[i];
   }
   for (int i = 0; i < work->p; ++i) {
       work->kkt_res[i + work->n] -= work->b[i];
   }
   for (int i = 0; i < work->m; ++i) {
       work->kkt_res[i + work->n + work->p] += (work->s[i] - work->h[i]);
   }

}

void construct_kkt_aff_rhs(Workspace* work) {
   copy_and_negate_arrayf(work->kkt_res, work->kkt_rhs, work->n + work->p + work->m);
   nt_multiply(work->W, work->lambda, work->ubuff1);
   for (int i = 0; i < work->m; ++i) {
       work->kkt_rhs[work->n + work->p + i] += work->ubuff1[i];
   }
}

void construct_kkt_comb_rhs(Workspace* work) {
   copy_and_negate_arrayf(work->kkt_res, work->kkt_rhs, work->n + work->p + work->m);
   nt_multiply(work->Winv, work->Ds, work->ubuff1);
   nt_multiply(work->W, &work->xyz[work->n + work->p], work->ubuff2);
   cone_product(work->ubuff1, work->ubuff2, work->ubuff3, work->l, work->nsoc, work->q);
   double sm = work->sigma * work->mu;
   int idx = 0;
   for (idx = 0; idx < work->l; ++idx) {
       work->ubuff3[idx] -= sm;
   }
   for (int i = 0; i < work->nsoc; ++i) {
       work->ubuff3[idx] -= sm;
       idx += work->q[i];
   }
   cone_product(work->lambda, work->lambda, work->ubuff1, work->l, work->nsoc, work->q);
   for (int i = 0; i < work->m; ++i) {
       work->Ds[i] = -work->ubuff1[i] - work->ubuff3[i];
   }
   cone_division(work->lambda, work->Ds, work->ubuff2, work->l, work->nsoc, work->q);
   nt_multiply(work->W, work->ubuff2, work->ubuff1);
   for (int i = 0; i < work->m; ++i) {
       work->kkt_rhs[work->n + work->p + i] -= work->ubuff1[i];
   }
}

void predictor_corrector(Workspace* work) {
   ldl(work);

   // Construct rhs for affine scaling direction.
   construct_kkt_aff_rhs(work);

   // Solve KKT system to get affine scaling direction.
   kkt_solve(work);

   // Compute Dsaff.
   nt_multiply(work->W, &work->xyz[work->n + work->p], work->ubuff1);
   for (int i = 0; i < work->m; ++i) {
       work->ubuff1[i] = -work->lambda[i] - work->ubuff1[i];
   }
   nt_multiply(work->W, work->ubuff1, work->Ds);

   compute_centering(work);
   construct_kkt_comb_rhs(work);
   kkt_solve(work);

   // Check if solution has NaNs. If NaNs are present, early exit and set a to 0.0 to trigger reduced tolerance optimality checks.
   for (int i = 0; i < work->n + work->m + work->p; ++i) {
       if (isnan(work->xyz[i])) {
           work->a = 0.0;
           return;
       }
   }
   // Compute Dz.
   cone_division(work->lambda, work->Ds, work->ubuff1, work->l, work->nsoc, work->q);
   nt_multiply(work->W, &work->xyz[work->n + work->p], work->ubuff2);
   for (int i = 0; i < work->m; ++i) {
       work->ubuff3[i] = work->ubuff1[i] - work->ubuff2[i];
   }
   nt_multiply(work->W, work->ubuff3, work->Ds);

   // Compute step-size.
   double a = qoco_min(linesearch(work->s, work->Ds, 0.99, work), linesearch(work->z, &work->xyz[work->n + work->p], 0.99, work));
   work->a = a;

   // Update iterate.
   for (int i = 0; i < work->n; ++i) {
       work->x[i] += a * work->xyz[i];
   }
   for (int i = 0; i < work->m; ++i) {
       work->s[i] += a * work->Ds[i];
   }
   for (int i = 0; i < work->p; ++i) {
       work->y[i] += a * work->xyz[work->n + i];
   }
   for (int i = 0; i < work->m; ++i) {
       work->z[i] += a * work->xyz[work->n + work->p + i];
   }
}
