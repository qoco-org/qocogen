void qoco_custom_scale_arrayf(double* x, double* y, double s, int n) {
   for (int i = 0; i < n; ++i) {
       y[i] = s * x[i];
   }
}

void qoco_custom_ew_product(double* x, double* y, double* z, int n) {
   for (int i = 0; i < n; ++i) {
       z[i] = x[i] * y[i];
   }
}

void qoco_custom_axpy(double* x, double* y, double* z, double a, int n) {
   for (int i = 0; i < n; ++i) {
       z[i] = a * x[i] + y[i];
   }
}

unsigned char check_stopping(Workspace* work) {
   // Compute objective.
   double obj = qoco_custom_dot(work->c, work->x, work->n);
   qoco_custom_Px(work->x, work->xbuff, work);
   double xqoco_custom_Px = qoco_custom_dot(work->x, work->xbuff, work->n);
   obj += 0.5 * qoco_custom_dot(work->x, work->xbuff, work->n);
   work->sol.obj = obj * work->kinv;
   qoco_custom_ew_product(work->xbuff, work->Dinvruiz, work->xbuff, work->n);
   double qoco_custom_Pxinf = qoco_custom_inf_norm(work->xbuff, work->n);

   // Compute primal residual, dual residual, and duality gap.
   qoco_custom_ew_product(&work->kkt_res[work->n], work->Einvruiz, work->xbuff, work->p);
   double eq_res = qoco_custom_inf_norm(work->xbuff, work->p);
   qoco_custom_ew_product(&work->kkt_res[work->n + work->p], work->Finvruiz, work->ubuff1, work->m);
   double conic_res = qoco_custom_inf_norm(work->ubuff1, work->m);
   double pres = qoco_max(eq_res, conic_res);
   qoco_custom_ew_product(work->kkt_res, work->Dinvruiz, work->xbuff, work->n);
   qoco_custom_scale_arrayf(work->xbuff, work->xbuff, work->kinv, work->n);
   double dres = qoco_custom_inf_norm(work->xbuff, work->n);
   work->sol.pres = pres;
   work->sol.dres = dres;

   qoco_custom_ew_product(work->s, work->Fruiz, work->ubuff1, work->m);
   qoco_custom_ew_product(work->z, work->Fruiz, work->ubuff2, work->m);
   double gap = qoco_custom_dot(work->ubuff1, work->ubuff2, work->m);
   gap *= work->kinv;
   work->sol.gap = gap;

   qoco_custom_ew_product(work->Einvruiz, work->b, work->xbuff, work->p);
   double binf = work->p > 0 ? qoco_custom_inf_norm(work->xbuff, work->p) : 0;

   qoco_custom_ew_product(work->Fruiz, work->s, work->ubuff1, work->m);
   double sinf = work->m > 0 ? qoco_custom_inf_norm(work->ubuff1, work->m) : 0;

   qoco_custom_ew_product(work->Dinvruiz, work->x, work->xbuff, work->n);
   double cinf = work->n > 0 ? qoco_custom_inf_norm(work->xbuff, work->n) : 0;

   qoco_custom_ew_product(work->Finvruiz, work->h, work->ubuff3, work->m);
   double hinf = work->m > 0 ? qoco_custom_inf_norm(work->ubuff3, work->m) : 0;

   Gtx(work->z, work->xbuff, work);
   qoco_custom_ew_product(work->xbuff, work->Dinvruiz, work->xbuff, work->n);
   double Gtzinf = qoco_custom_inf_norm(work->xbuff, work->n);

   Atx(work->y, work->xbuff, work);
   qoco_custom_ew_product(work->xbuff, work->Dinvruiz, work->xbuff, work->n);
   double Atyinf = qoco_custom_inf_norm(work->xbuff, work->n);

   Gx(work->x, work->ubuff1, work);
   qoco_custom_ew_product(work->ubuff1, work->Finvruiz, work->ubuff1, work->m);
   double Gxinf = qoco_custom_inf_norm(work->ubuff1, work->m);
   qoco_custom_Ax(work->x, work->xbuff, work);
   qoco_custom_ew_product(work->xbuff, work->Einvruiz, work->xbuff, work->p);
   double Axinf = qoco_custom_inf_norm(work->xbuff, work->p);

   // Compute max{Axinf, binf, Gxinf, hinf, sinf}.
   double pres_rel = qoco_max(Axinf, binf);
   pres_rel = qoco_max(pres_rel, Gxinf);
   pres_rel = qoco_max(pres_rel, hinf);
   pres_rel = qoco_max(pres_rel, sinf);

   // Compute max{qoco_custom_Pxinf, Atyinf, Gtzinf, cinf}.
   double dres_rel = qoco_max(qoco_custom_Pxinf, Atyinf);
   dres_rel = qoco_max(dres_rel, Gtzinf);
   dres_rel = qoco_max(dres_rel, cinf);
   dres_rel *= work->kinv;

   // Compute max{sinf, zinf}.
   double ctx = qoco_custom_dot(work->c, work->x, work->n);
   double bty = qoco_custom_dot(work->b, work->y, work->p);
   double htz = qoco_custom_dot(work->h, work->z, work->m);

   double pobj = 0.5 * xqoco_custom_Px + ctx;
   double dobj = -0.5 * xqoco_custom_Px - bty - htz;
   pobj = qoco_abs(pobj);
   dobj = qoco_abs(dobj);

   double gap_rel = qoco_max(1, pobj);
   gap_rel = qoco_max(gap_rel, dobj);

   // If the solver stalled (a = 0) check if low tolerance stopping criteria is met.
   if(work->a < 1e-8) {
      if (pres < work->settings.abstol_inacc + work->settings.reltol_inacc * pres_rel && dres < work->settings.abstol_inacc + work->settings.reltol_inacc * dres_rel && work->sol.gap < work->settings.abstol_inacc + work->settings.reltol_inacc * gap_rel) {
           work->sol.status = QOCO_CUSTOM_SOLVED_INACCURATE;
           return 1;
      }
      else {
           work->sol.status = QOCO_CUSTOM_NUMERICAL_ERROR;
           return 1;
      }
   }
   if (pres < work->settings.abstol + work->settings.reltol * pres_rel && dres < work->settings.abstol + work->settings.reltol * dres_rel && work->sol.gap < work->settings.abstol + work->settings.reltol * gap_rel) {
      work->sol.status = QOCO_CUSTOM_SOLVED;
      return 1;
   }
   return 0;
}

void copy_solution(Workspace* work) {
   qoco_custom_copy_arrayf(work->x, work->sol.x, work->n);
   qoco_custom_copy_arrayf(work->s, work->sol.s, work->m);
   qoco_custom_copy_arrayf(work->y, work->sol.y, work->p);
   qoco_custom_copy_arrayf(work->z, work->sol.z, work->m);
}

void unscale_solution(Workspace* work) {
   qoco_custom_ew_product(work->x, work->Druiz, work->x, work->n);
   qoco_custom_ew_product(work->s, work->Finvruiz, work->s, work->m);
   qoco_custom_ew_product(work->y, work->Eruiz, work->y, work->p);
   qoco_custom_scale_arrayf(work->y, work->y, work->kinv, work->p);
   qoco_custom_ew_product(work->z, work->Fruiz, work->z, work->m);
   qoco_custom_scale_arrayf(work->z, work->z, work->kinv, work->m);
}

