void set_default_settings(Workspace* work) {
   work->settings.max_iters = 200;
   work->settings.bisect_iters = 5;
{% if generate_ruiz %}
   work->settings.ruiz_iters = 5;
{% else %}
   work->settings.ruiz_iters = 0;
{% endif %}
   work->settings.iter_ref_iters = 1;
   work->settings.kkt_static_reg = 1e-8;
   work->settings.kkt_dynamic_reg = 1e-8;
   work->settings.abstol = 1e-7;
   work->settings.reltol = 1e-7;
   work->settings.abstol_inacc = 1e-5;
   work->settings.reltol_inacc = 1e-5;
   work->settings.verbose = 0;
}

void qoco_custom_copy_arrayf(double* x, double* y, int n) {
   for (int i = 0; i < n; ++i) {
      y[i] = x[i];
   }
}

void copy_and_negate_arrayf(double* x, double* y, int n) {
   for (int i = 0; i < n; ++i) {
      y[i] = -x[i];
   }
}

double qoco_custom_dot(double* x, double* y, int n) {
   double ans = 0;
      for (int i = 0; i < n; ++i) {
         ans += x[i] * y[i];
      }
   return ans;
}

double qoco_custom_inf_norm(double* x, int n) {
   double norm = 0.0;
   double xi;
   for (int i = 0; i < n; ++i) {
       xi = qoco_abs(x[i]);
       norm = qoco_max(norm , xi);
   }
   return norm;
}

