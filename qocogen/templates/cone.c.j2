double linesearch(double* u, double* Du, double f, Workspace* work) {
   if (work->nsoc == 0) {
       return exact_linesearch(u, Du, f, work);
   }
   else {
       return bisection_search(u, Du, f, work);
   }
}

double bisection_search(double* u, double* Du, double f, Workspace* work) {
   double al = 0.0;
   double au = 1.0;
   double a = 0.0;
   for (int i = 0; i < work->settings.bisect_iters; ++i) {
       a = 0.5 * (al + au);
       qoco_custom_axpy(Du, u, work->ubuff1, safe_div(a, f), work->m);
       if (cone_residual(work->ubuff1, work->l, work->nsoc, work->q) >= 0) {
           au = a;
       }
       else {
           al = a;
       }
   }
   return al;
}

double exact_linesearch(double* u, double* Du, double f, Workspace* work) {
   double a = 1.0;
   double minval = 0;
   // Compute a for LP cones.
   for (int i = 0; i < work->l; ++i) {
       if (Du[i] < minval * u[i])
           minval = Du[i] / u[i];

   }
   if (-f < minval)
       a = f;
   else
       a = -f / minval;

   return a;
}

void compute_centering(Workspace* work) {
   double a = qoco_min(linesearch(work->z, &work->xyz[work->n + work->p], 1.0, work), linesearch(work->s, work->Ds, 1.0, work));
   qoco_custom_axpy(&work->xyz[work->n + work->p], work->z, work->ubuff1, a, work->m);
   qoco_custom_axpy(work->Ds, work->s, work->ubuff2, a, work->m);
   double rho = safe_div(qoco_custom_dot(work->ubuff1, work->ubuff2, work->m), qoco_custom_dot(work->z, work->s, work->m));
   double sigma = qoco_min(1.0, rho);
   sigma = qoco_max(0.0, sigma);
   sigma = sigma * sigma * sigma;
   work->sigma = sigma;
}
