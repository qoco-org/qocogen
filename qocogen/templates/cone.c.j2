void soc_product(double* u, double* v, double* p, int n) {
   p[0] = qoco_custom_dot(u, v, n);
   for (int i = 1; i < n; ++i) {
       p[i] = u[0] * v[i] + v[0] * u[i];
   }
}

void soc_division(double* lam, double* v, double* d, int n) {
   double f = lam[0] * lam[0] - qoco_custom_dot(&lam[1], &lam[1], n - 1);
   double finv = safe_div(1.0, f);
   double lam0inv = safe_div(1.0, lam[0]);
   double lam1dv1 = qoco_custom_dot(&lam[1], &v[1], n - 1);
   d[0] = finv * (lam[0] * v[0] - qoco_custom_dot(&lam[1], &v[1], n - 1));
   for (int i = 1; i < n; ++i) {
       d[i] = finv * (-lam[i] * v[0] + lam0inv * f * v[i] + lam0inv * lam1dv1 * lam[i]);
   }
}

double soc_residual(double* u, int n) {
   double res = 0;
   for (int i = 1; i < n; ++i) {
      res += u[i] * u[i];
   }
   res = qoco_sqrt(res) - u[0];
   return res;
}

double soc_residual2(double* u, int n) {
   double res = u[0] * u[0];
   for (int i = 1; i < n; ++i) {
      res -= u[i] * u[i];
   }
   return res;
}

double cone_residual(double* u, int l, int nsoc, int* q) {
   double res = -1e7;
   int idx;
   for (idx = 0; idx < l; ++idx) {
      res = qoco_max(-u[idx], res);
   }
   for (int i = 0; i < nsoc; ++i) {
      res = qoco_max(soc_residual(&u[idx], q[i]), res);
      idx += q[i];
   }
   return res;
}

void bring2cone(double* u, int l, int nsoc, int* q) {
   if (cone_residual(u, l, nsoc, q) >= 0) {
      double a = 0.0;

      int idx;
      for (idx = 0; idx < l; ++idx) {
         a = qoco_max(a, -u[idx]);
      }
      a = qoco_max(a, 0.0);

      for (int i = 0; i < nsoc; ++i) {
         double soc_res = soc_residual(&u[idx], q[i]);
         if (soc_res > 0 && soc_res > a) {
            a = soc_res;
         }
         idx += q[i];
      }
      for (idx = 0; idx < l; ++idx) {
         u[idx] += (1 + a);
      }
      for (int i = 0; i < nsoc; ++i) {
         u[idx] += (1 + a);
         idx += q[i];
      }
   }
}

void cone_product(double* u, double* v, double* p, int l, int nsoc, int* q) {
   int idx;
   for (idx = 0; idx < l; ++idx) {
       p[idx] = u[idx] * v[idx];
   }
   for (int i = 0; i < nsoc; ++i) {
       soc_product(&u[idx], &v[idx], &p[idx], q[i]);
       idx += q[i];
   }
}

void cone_division(double* lambda, double* v, double* d, int l, int nsoc, int* q) {
   int idx;
   for (idx = 0; idx < l; ++idx) {
       d[idx] = safe_div(v[idx], lambda[idx]);
   }
   for (int i = 0; i < nsoc; ++i) {
       soc_division(&lambda[idx], &v[idx], &d[idx], q[i]);
       idx += q[i];
   }
}

