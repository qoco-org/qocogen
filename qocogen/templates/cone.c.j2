void compute_nt_scaling(Workspace* work) {
{% for i in range(Wnnz) %}
   work->W[{{ i }}] = 0.0;
   work->Winv[{{ i }}] = 0.0;
{% endfor %}
   int idx;
   for (idx = 0; idx < work->l; ++idx) {
       work->W[idx] = qoco_sqrt(safe_div(work->s[idx], work->z[idx]));
       work->Winv[idx] = safe_div(1.0, work->W[idx]);
   }

   int nt_idx = idx;
   for (int i = 0; i < work->nsoc; ++i) {
       // Compute normalized vectors.
       double s_scal = soc_residual2(&work->s[idx], work->q[i]);
       s_scal = qoco_sqrt(s_scal);
       double f = safe_div(1.0, s_scal);
       qoco_custom_scale_arrayf(&work->s[idx], work->sbar, f, work->q[i]);

       double z_scal = soc_residual2(&work->z[idx], work->q[i]);
       z_scal = qoco_sqrt(z_scal);
       f = safe_div(1.0, z_scal);
       qoco_custom_scale_arrayf(&work->z[idx], work->zbar, f, work->q[i]);

       double gamma = qoco_sqrt(0.5 * (1 + qoco_custom_dot(work->sbar, work->zbar, work->q[i])));
       f = safe_div(1.0, (2 * gamma));

       // Overwrite sbar with wbar.
       work->sbar[0] = f * (work->sbar[0] + work->zbar[0]);
       for (int j = 1; j < work->q[i]; ++j) {
           work->sbar[j] = f * (work->sbar[j] - work->zbar[j]);
       }

       // Overwrite zbar with v.
       f = safe_div(1.0, qoco_sqrt(2 * (work->sbar[0] + 1)));
       work->zbar[0] = f * (work->sbar[0] + 1.0);
       for (int j = 1; j < work->q[i]; ++j) {
           work->zbar[j] = f * work->sbar[j];
       }

       // Compute W for second-order cones.
       int shift = 0;
       f = qoco_sqrt(safe_div(s_scal, z_scal));
       double finv = safe_div(1.0, f);
       for (int j = 0; j < work->q[i]; ++j) {
           for (int k = 0; k <= j; ++k) {
               work->W[nt_idx + shift] = 2 * (work->zbar[k] * work->zbar[j]);
               if (j != 0 && k == 0) {
                   work->Winv[nt_idx + shift] = -work->W[nt_idx + shift];
               }
               else {
                   work->Winv[nt_idx + shift] = work->W[nt_idx + shift];
               }
               if (j == k && j == 0) {
                   work->W[nt_idx + shift] -= 1;
                   work->Winv[nt_idx + shift] -= 1;
               }
               else if (j == k) {
                   work->W[nt_idx + shift] += 1;
                   work->Winv[nt_idx + shift] += 1;
               }
               work->W[nt_idx + shift] *= f;
               work->Winv[nt_idx + shift] *= finv;
               shift += 1;
           }
       }
       idx += work->q[i];
       nt_idx += (work->q[i] * work->q[i] + work->q[i]) / 2;
   }
}

